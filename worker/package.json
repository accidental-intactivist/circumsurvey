{
  "name": "circumsurvey-api",
  "version": "1.0.0",
  "description": "CircumSurvey D1-backed API Worker",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "tail": "wrangler tail",
    "db:schema": "wrangler d1 execute circumsurvey --remote --file ../schemas/schema.sql",
    "db:seed": "wrangler d1 execute circumsurvey --remote --file ../data/seed.sql",
    "db:count": "wrangler d1 execute circumsurvey --remote --command 'SELECT COUNT(*) FROM respondents'"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
